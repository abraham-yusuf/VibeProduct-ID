# ============================================
# DATABASE (Neon PostgreSQL)
# Daftar di: https://neon.tech
# ============================================
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# ============================================
# AUTH (Better Auth)
# Generate secret: openssl rand -base64 32
# ============================================
BETTER_AUTH_SECRET=your-secret-key-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# ============================================
# AI PROVIDERS (opsional, bisa diset via dashboard)
# ============================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# ============================================
# PAYMENT (Midtrans)
# Daftar di: https://midtrans.com
# ============================================
MIDTRANS_SERVER_KEY=SB-Mid-server-...
MIDTRANS_CLIENT_KEY=SB-Mid-client-...
MIDTRANS_IS_PRODUCTION=false

# ============================================
# EMAIL (Resend)
# Daftar di: https://resend.com
# ============================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@vibeproduct.biz.id
ADMIN_EMAIL=admin@vibeproduct.biz.id

# ============================================
# STORAGE (Vercel Blob)
# Otomatis tersedia di Vercel
# ============================================
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Vibe Product ID
NEXT_PUBLIC_WHATSAPP_NUMBER=628xxxxxxxxxx

# Ads
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=xxxxxxxxxx
NEXT_PUBLIC_ADSENSE_SLOT_CONTENT=xxxxxxxxxx
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=xxxxxxxxxx